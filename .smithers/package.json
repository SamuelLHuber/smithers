{
  "name": "smithers-workflows",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test ./tests/open-code-review.test.ts ./tests/open-code-review-ui.e2e.test.ts",
    "lint": "oxlint --react-plugin --node-plugin --import-plugin --ignore-path ../.gitignore .",
    "lint:fix": "oxlint --react-plugin --node-plugin --import-plugin --ignore-path ../.gitignore --fix .",
    "workflow:list": "smithers workflow list",
    "workflow:run": "smithers workflow run",
    "workflow:implement": "smithers workflow run implement",
    "release:content": "cd .. && pnpm release:content",
    "release:content:approve": "cd .. && pnpm release:content:approve",
    "release:content:publish": "cd .. && pnpm release:content:publish",
    "release:workflow": "cd .. && pnpm release:workflow",
    "release:workflow:gated": "cd .. && pnpm release:workflow:gated",
    "marketing:thread": "cd .. && pnpm marketing:thread",
    "marketing:thread:write": "cd .. && pnpm marketing:thread:write",
    "test:open-code-review": "bun test ./tests/open-code-review.test.ts ./tests/open-code-review-ui.e2e.test.ts"
  },
  "dependencies": {
    "@smithers-orchestrator/scorers": "workspace:*",
    "effect": "^3.21.1",
    "react": "^19.2.5",
    "smithers-orchestrator": "workspace:*",
    "twitter-api-v2": "^1.29.0",
    "zod": "4.3.6"
  },
  "optionalDependencies": {
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@types/mdx": "2.0.13",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "5.9.3"
  }
}
