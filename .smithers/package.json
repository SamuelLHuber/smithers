{
  "name": "smithers-workflows",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test ./tests/open-code-review.test.ts ./tests/open-code-review-ui.e2e.test.ts",
    "lint": "oxlint --react-plugin --node-plugin --import-plugin --ignore-path ../.gitignore .",
    "lint:fix": "oxlint --react-plugin --node-plugin --import-plugin --ignore-path ../.gitignore --fix .",
    "workflow:list": "smithers workflow list",
    "workflow:run": "smithers workflow run",
    "workflow:implement": "smithers workflow run implement",
    "test:open-code-review": "bun test ./tests/open-code-review.test.ts ./tests/open-code-review-ui.e2e.test.ts"
  },
  "dependencies": {
    "@smithers-orchestrator/scorers": "workspace:*",
    "smithers-orchestrator": "workspace:*",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/mdx": "2.0.13",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "5.9.3"
  }
}
