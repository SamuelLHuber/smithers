{
  "name": "@smithers-orchestrator/review",
  "version": "0.0.1",
  "private": true,
  "description": "Code review plus story-form HTML walkthrough, built on the OpenCodeReview-derived review flow",
  "type": "module",
  "bin": {
    "smithers-review": "./src/cli/main.ts"
  },
  "exports": {
    "./diffs": "./src/diffs/index.ts"
  },
  "scripts": {
    "start": "bun ./src/cli/main.ts",
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pierre/diffs": "^1.2.9",
    "@smithers-orchestrator/db": "workspace:*",
    "@smithers-orchestrator/engine": "workspace:*",
    "effect": "3.21.1",
    "smithers-orchestrator": "workspace:*",
    "smithers-workflows": "workspace:*",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "bun-types": "^1.3.12",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "typescript": "~5.9.3"
  }
}
