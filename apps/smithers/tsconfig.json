{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "typeRoots": ["../../node_modules", "../../node_modules/@types"],
    "types": ["bun-types"]
  },
  "include": ["src", "vite.config.ts"]
}
