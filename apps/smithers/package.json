{
  "name": "@smithers-orchestrator/smithers",
  "version": "0.1.0",
  "description": "Smithers — Cerebras chat PWA, deployable to Cloudflare via Alchemy",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "cf:dev": "alchemy dev",
    "deploy": "alchemy deploy",
    "destroy": "alchemy destroy"
  },
  "dependencies": {
    "@tanstack/ai": "^0.27.0",
    "@tanstack/ai-openai": "^0.13.0",
    "@tanstack/ai-react": "^0.15.3",
    "@xyflow/react": "^12.10.2",
    "dagre": "^0.8.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.39.2",
    "@cloudflare/workers-types": "^4.20260604.1",
    "@types/dagre": "^0.7.54",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "alchemy": "^0.93.11",
    "cloudflare": "^6.3.0",
    "tsx": "^4.22.4",
    "typescript": "~5.9.3",
    "vite": "^8.0.14"
  }
}
