  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/dagre": "^0.7.54",
    "@vitejs/plugin-react": "^6.0.2",
    "vite": "^8.0.14",
    "vitest": "^4.0.16"
  }
