{
  "name": "@smithers-orchestrator/smithers-demo",
  "version": "0.21.0",
  "description": "Interactive Smithers workflow generator demo with React Flow visualization",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
