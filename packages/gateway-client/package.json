{
  "name": "@smithers-orchestrator/gateway-client",
  "version": "0.24.1",
  "description": "Browser-first client SDK for the Smithers Gateway RPC and event stream APIs",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "build": "node ../../node_modules/tsup/dist/cli-default.js --dts-only",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "test": "bun test tests"
  },
  "dependencies": {
    "@smithers-orchestrator/gateway": "workspace:*",
    "@tanstack/db": "^0.6.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
