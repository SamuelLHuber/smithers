{
  "name": "@smithers-orchestrator/gateway-react",
  "version": "0.26.1",
  "description": "React hooks and root helpers for Smithers Gateway UIs",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "build": "node ../../node_modules/tsup/dist/cli-default.js --dts-only",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "test": "bun test tests"
  },
  "dependencies": {
    "@smithers-orchestrator/gateway": "workspace:*",
    "@smithers-orchestrator/gateway-client": "workspace:*",
    "@tanstack/react-db": "0.1.86"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@smithers-orchestrator/server": "workspace:*",
    "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "~5.9.3"
  }
}
