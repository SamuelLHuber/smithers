{
  "name": "@smithers-orchestrator/protocol",
  "version": "0.17.0",
  "description": "Shared Smithers contracts, errors, and small value types",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.d.ts"
    },
    "./errors": {
      "types": "./src/index.d.ts",
      "import": "./src/errors/index.js",
      "default": "./src/errors/index.js"
    },
    "./errors/index.js": {
      "types": "./src/index.d.ts",
      "import": "./src/errors/index.js",
      "default": "./src/errors/index.js"
    },
    "./*": {
      "types": "./src/index.d.ts",
      "import": "./src/*.js",
      "default": "./src/*.js"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "build": "tsup --dts-only",
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "effect": "^3.21.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
