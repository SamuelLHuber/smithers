{
  "name": "@smithers-orchestrator/electric-proxy",
  "version": "0.24.0",
  "description": "Auth, scope, rate-limit, and observability proxy for Smithers ElectricSQL Shapes",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "smithers-electric-proxy": "./bin/smithers-electric-proxy.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src/",
    "bin/"
  ],
  "scripts": {
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "test": "bun test tests"
  },
  "dependencies": {
    "@smithers-orchestrator/gateway": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
